# Build outputs
dist/
src-tauri/target/
src-tauri/gen/

# Dependencies
node_modules/

# Database (user-specific or bundled at build time — do not commit)
*.db
*.db-journal
*.db-wal
*.db-shm

# Downloaded ingest sources (auto-fetched by the scripts on demand)
data/*.json
data/*.zip
data/oshb/

# Built installers (distribute via GitHub Releases instead)
*.msi
*-setup.exe
*-setup.exe.sig

# Logs
*.log
logs/
cron_output/
.cron_check.log

# Python cache
__pycache__/
*.pyc
*.pyo

# OS
.DS_Store
Thumbs.db
*.swp

# IDE / agent state
.claude/
