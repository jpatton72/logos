{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Logos",
  "version": "1.0.0",
  "identifier": "com.logos.biblestudy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Logos — Bible Study",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Scholarly Bible study application with original languages and AI assistance",
    "longDescription": "Logos is a desktop Bible study application featuring the full Hebrew and Greek original texts, side-by-side translation comparison, Strong's Concordance integration, morphological analysis, personal notes and bookmarks, and AI-powered study assistance.",
    "copyright": "2025",
    "publisher": "Logos"
  },
  "plugins": {}
}
